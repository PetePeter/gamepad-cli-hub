# keep graph outputs, skip heavy/local-only files

# optional: commit for shared extraction speed, skip to keep repo small
graphify-out/cache/

# mtime-based, invalid after git clone - always gitignore this
graphify-out/manifest.json

# local token tracking, not useful to share
graphify-out/cost.json

node_modules/
dist/
dist-electron/
*.log
.DS_Store
logs/
.test-config-*/
__pycache__/

# Build output (generated by esbuild/tsc)
renderer/main.js
renderer/main.js.map
src/**/*.js
src/**/*.js.map

# Release artifacts (large EXEs)
release/
/config/
config-deploy/
tmp/helm-work*
tmp/helm-attachment*

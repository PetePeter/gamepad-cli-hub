{
  "name": "gamepad-cli-hub",
  "version": "1.4.1",
  "main": "dist-electron/main.js",
  "type": "module",
  "description": "Helm \u2014 steer your fleet of agents",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "build": "npm run build:electron && npm run build:preload && npm run build:renderer",
    "build:electron": "esbuild src/electron/main.ts --bundle --platform=node --external:electron --external:@jitsi/robotjs --external:node-pty --external:yaml --external:winston --external:winston-daily-rotate-file --external:node-telegram-bot-api --external:chokidar --outfile=dist-electron/main.js --format=esm --sourcemap",
    "build:preload": "esbuild src/electron/preload.ts --bundle --platform=node --external:electron --outfile=dist-electron/preload.cjs --format=cjs --sourcemap",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "package": "npm run build && electron-builder --win --x64",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "gamepad",
    "cli",
    "controller",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.gamepadcli.hub",
    "productName": "Helm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/renderer/**/*",
      "config/**/*",
      {
        "from": "config-deploy",
        "to": "config",
        "filter": [
          "**/*"
        ]
      },
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": [
          "icon.ico",
          "icon.png"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Helm"
    }
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.21",
    "@vitejs/plugin-vue": "^6.0.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "node-gyp": "^12.2.0",
    "tsx": "^4.21.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@electron/rebuild": {
      "node-gyp": "^12.2.0"
    }
  }
}

{
  "name": "gamepad-cli-hub",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "description": "Xbox controller to multi-CLI session manager with GUI",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "build": "npm run build:electron && npm run build:preload && npm run build:renderer",
    "build:electron": "esbuild src/electron/main.ts --bundle --platform=node --external:electron --external:@jitsi/robotjs --external:node-pty --external:yaml --external:winston --external:winston-daily-rotate-file --outfile=dist-electron/main.js --format=esm --sourcemap",
    "build:preload": "esbuild src/electron/preload.ts --bundle --platform=node --external:electron --outfile=dist-electron/preload.cjs --format=cjs --sourcemap",
    "build:renderer": "esbuild renderer/main.ts --bundle --sourcemap --outfile=dist/renderer/main.js --format=esm --target=es2022",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "gamepad",
    "cli",
    "controller",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@jitsi/robotjs": "^0.6.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.5.0",
    "@vitest/ui": "^4.1.0",
    "electron": "^41.0.3",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
